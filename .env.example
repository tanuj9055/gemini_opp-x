# ── Gemini API ────────────────────────────────────────
# Get your API key from: https://ai.google.dev/gemini-api/docs/api-key
GOOGLE_API_KEY=your-actual-gemini-api-key-here

# ── App Settings ──────────────────────────────────────
APP_ENV=development
LOG_LEVEL=DEBUG

# ── Gemini Model ──────────────────────────────────────
GEMINI_MODEL=gemini-1.5-pro

# ── Upload limits (bytes) ─────────────────────────────
MAX_FILE_SIZE_MB=50
